{
  "name": "@flowcore/data-pump",
  "description": "Flowcore Data Pump",
  "version": "0.21.4",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "import": "./dist/mod.js"
    }
  },
  "types": "./dist/mod.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "homepage": "https://github.com/flowcore-io/flowcore-data-pump#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flowcore-io/flowcore-data-pump.git"
  },
  "bugs": {
    "url": "https://github.com/flowcore-io/flowcore-data-pump/issues"
  },
  "scripts": {
    "build": "tsup src/mod.ts --format esm --dts --clean --out-dir dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@date-fns/utc": "^2.1.0",
    "@flowcore/sdk": "^4.2.3",
    "@flowcore/sdk-oidc-client": "^1.3.1",
    "@flowcore/time-uuid": "^0.2.0",
    "@sinclair/typebox": "0.32.15",
    "date-fns": "^4.1.0",
    "nats": "^2.29.1",
    "prom-client": "^15.1.3",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.10",
    "pg": "^8.13.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
